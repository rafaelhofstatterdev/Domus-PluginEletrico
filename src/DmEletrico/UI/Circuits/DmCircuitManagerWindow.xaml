<Window x:Class="DmEletrico.UI.Circuits.DmCircuitManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DmEletrico — Gerenciador de Circuitos"
        Width="640" Height="480"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="Grid" Grid.Column="0" Margin="0,0,12,0"
                  ItemsSource="{Binding Circuitos}" AutoGenerateColumns="False"
                  IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Circuito" Binding="{Binding Numero}" Width="70" />
                <DataGridTextColumn Header="QDC" Binding="{Binding Painel}" Width="*" />
                <DataGridTextColumn Header="Fase" Binding="{Binding Fase}" Width="50" />
                <DataGridTextColumn Header="Carga" Binding="{Binding CargaStr}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="1">
            <TextBlock Text="Ações" FontWeight="SemiBold" Margin="0,0,0,6" />
            <Button Content="Reatribuir a outro QDC" Margin="0,0,0,6" Padding="6" Click="OnReatribuir" />
            <TextBlock Text="Novo número:" Margin="0,4,0,2" />
            <TextBox x:Name="NovoNumero" Margin="0,0,0,4" />
            <Button Content="Renumerar" Margin="0,0,0,6" Padding="6" Click="OnRenumerar" />
            <Button Content="Balancear Fases" Margin="0,0,0,6" Padding="6" Click="OnBalancear" />
            <Separator Margin="0,8" />
            <Button Content="Atualizar" Margin="0,0,0,6" Padding="6" Click="OnAtualizar" />
            <TextBlock x:Name="Status" TextWrapping="Wrap" Foreground="#555" Margin="0,10,0,0" />
            <Button Content="Fechar" Margin="0,16,0,0" Padding="6" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
