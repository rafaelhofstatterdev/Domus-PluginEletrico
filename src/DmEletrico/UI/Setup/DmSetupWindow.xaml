<Window x:Class="DmEletrico.UI.Setup.DmSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:DmEletrico.UI.Converters"
        Title="DmEletrico — Setup do Projeto"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <conv:FlexibleDoubleConverter x:Key="Dbl" />
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,2" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
    <StackPanel Margin="16">

        <TextBlock Text="Configuração do DmEletrico" FontSize="16" Margin="0,0,0,4" />
        <TextBlock Text="Os parâmetros compartilhados serão injetados no modelo ao confirmar."
                   FontWeight="Normal" TextWrapping="Wrap" Foreground="#555" />

        <TextBlock Text="Temperatura ambiente (°C) — para o FCT" />
        <TextBox Text="{Binding TemperaturaAmbiente, Converter={StaticResource Dbl}, UpdateSourceTrigger=LostFocus}" />

        <TextBlock Text="Tensão nominal do sistema (V)" />
        <ComboBox ItemsSource="{Binding TensoesDisponiveis}"
                  SelectedItem="{Binding TensaoNominal}" />

        <TextBlock Text="Método de instalação dos condutores" />
        <ComboBox ItemsSource="{Binding MetodosDisponiveis}"
                  SelectedItem="{Binding Metodo}" />

        <TextBlock Text="Modo de roteamento" />
        <ComboBox ItemsSource="{Binding ModosDisponiveis}" SelectedItem="{Binding Modo}" />

        <TextBlock Text="Tipo de conduíte" />
        <ComboBox ItemsSource="{Binding TiposConduite}" SelectedItem="{Binding TipoConduite}" />

        <TextBlock Text="Altura de roteamento padrão (m)" />
        <TextBox Text="{Binding AlturaRoteamento, Converter={StaticResource Dbl}, UpdateSourceTrigger=LostFocus}" />

        <TextBlock Text="Offsets por ambiente (m): laje / parede / contrapiso" />
        <StackPanel Orientation="Horizontal">
            <TextBox Width="120" Margin="0,0,8,0" Text="{Binding OffsetLaje, Converter={StaticResource Dbl}, UpdateSourceTrigger=LostFocus}" />
            <TextBox Width="120" Margin="0,0,8,0" Text="{Binding OffsetParede, Converter={StaticResource Dbl}, UpdateSourceTrigger=LostFocus}" />
            <TextBox Width="120" Text="{Binding OffsetContrapiso, Converter={StaticResource Dbl}, UpdateSourceTrigger=LostFocus}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Width="90" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="Confirmar" Width="90" IsDefault="True" Click="OnConfirmar" />
        </StackPanel>
    </StackPanel>
</Window>
