<Window x:Class="DmEletrico.UI.DocCenter.DmDocCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DmEletrico — Central de Documentação"
        Width="560" Height="520"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="190" />
        </Grid.ColumnDefinitions>

        <!-- Árvore de QDCs e circuitos -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top" Text="Quadros de Distribuição (QDCs)"
                       FontWeight="SemiBold" Margin="0,0,0,6" />
            <TreeView ItemsSource="{Binding Quadros}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Circuitos}">
                        <TextBlock Text="{Binding Nome}" FontWeight="SemiBold" />
                        <HierarchicalDataTemplate.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Descricao}" />
                            </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </DockPanel>

        <!-- Ações -->
        <StackPanel Grid.Column="1">
            <TextBlock Text="Geração" FontWeight="SemiBold" Margin="0,0,0,6" />
            <Button Content="Quadro de Cargas" Margin="0,0,0,6" Padding="6" Click="OnQuadroCargas" />
            <Button Content="Quantitativos" Margin="0,0,0,6" Padding="6" Click="OnQuantitativos" />
            <Button Content="Diagrama Unifilar" Margin="0,0,0,6" Padding="6" Click="OnUnifilar" />
            <Button Content="Atualizar Unifilar" Margin="0,0,0,6" Padding="6" Click="OnRegenerarUnifilar" />
            <Button Content="Gerar Pranchas" Margin="0,0,0,6" Padding="6" Click="OnPranchas" />
            <Separator Margin="0,8" />
            <Button Content="Atualizar lista" Margin="0,0,0,6" Padding="6" Click="OnAtualizar" />
            <TextBlock x:Name="Status" TextWrapping="Wrap" Foreground="#555" Margin="0,10,0,0" />
            <Button Content="Fechar" Margin="0,16,0,0" Padding="6" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
