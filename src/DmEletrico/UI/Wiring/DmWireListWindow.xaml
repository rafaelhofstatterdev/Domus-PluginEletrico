<Window x:Class="DmEletrico.UI.Wiring.DmWireListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DmEletrico — Tabela de Fiação"
        Width="620" Height="460"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Quantitativo de condutores por bitola"
                   FontWeight="SemiBold" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Copiar" Width="100" Margin="0,0,8,0" Click="OnCopiar" />
            <Button Content="Fechar" Width="100" IsCancel="True" />
        </StackPanel>

        <DataGrid x:Name="Grid" ItemsSource="{Binding}" AutoGenerateColumns="False"
                  IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Bitola (mm²)" Binding="{Binding SecaoMm2, StringFormat=N2}" Width="90" />
                <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="*" />
                <DataGridTextColumn Header="Metros" Binding="{Binding MetrosBase, StringFormat=N1}" Width="90" />
                <DataGridTextColumn Header="Com folga" Binding="{Binding MetrosComFolga, StringFormat=N1}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
