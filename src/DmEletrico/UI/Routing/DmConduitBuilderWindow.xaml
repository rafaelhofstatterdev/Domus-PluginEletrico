<Window x:Class="DmEletrico.UI.Routing.DmConduitBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DmEletrico — Construir Conduítes"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,2" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
    <StackPanel Margin="16">

        <GroupBox Header="Modo de seleção" Padding="6">
            <ComboBox ItemsSource="{Binding Modos}" SelectedItem="{Binding Modo}" />
        </GroupBox>

        <GroupBox Header="Configurações dos conduítes" Padding="6" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="Tipo de Conduíte de Teto/Piso" />
                <ComboBox ItemsSource="{Binding TiposConduite}" SelectedItem="{Binding TipoTetoPiso}" />

                <TextBlock Text="Tipo de Conduíte de Parede" />
                <ComboBox ItemsSource="{Binding TiposConduite}" SelectedItem="{Binding TipoParede}" />

                <TextBlock Text="Diâmetro do Conduíte" />
                <ComboBox ItemsSource="{Binding Diametros}" SelectedItem="{Binding Diametro}" />

                <TextBlock Text="Caminho do conduíte" />
                <ComboBox ItemsSource="{Binding Caminhos}" SelectedItem="{Binding Caminho}" />
                <TextBlock Text="O roteamento é sempre ortogonal e pelo menor percurso."
                           FontWeight="Normal" Foreground="#777" Margin="0,2,0,0" />
            </StackPanel>
        </GroupBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Width="100" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="Selecionar" Width="100" IsDefault="True" Click="OnSelecionar" />
        </StackPanel>
    </StackPanel>
</Window>
